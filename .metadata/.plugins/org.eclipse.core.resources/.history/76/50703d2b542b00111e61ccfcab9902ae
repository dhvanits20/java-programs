package q15;

public class EmployeePayrollSystem {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of employees: ");
        int n = sc.nextInt();
        Employee[] employees = new Employee[n];
        int count = 0;

        while (count < n) {
            System.out.println("\nEnter details for employee " + (count + 1) + ":");
            try {
                System.out.print("Enter ID: ");
                int id = sc.nextInt();
                System.out.print("Enter Name: ");
                String name = sc.next();
                System.out.print("Enter Basic Salary: ");
                double salary = sc.nextDouble();
                System.out.print("Role (1 for Employee, 2 for Manager): ");
                int role = sc.nextInt();

                if (role == 1) {
                    employees[count] = new Employee(id, name, salary);
                } else {
                    employees[count] = new Manager(id, name, salary);
                }
                count++;
            } catch (InvalidSalaryException e) {
                System.out.println("Failed to create record: " + e.getMessage());
                System.out.println("Please try entering this employee's details again.");
            }
        }

        System.out.println("\n--- Payroll Report ---");
        for (Employee emp : employees) {
            System.out.println("ID: " + emp.id + " | Name: " + emp.name + " | Gross Salary: Rs. " + emp.calculateGrossSalary());
        }
        sc.close();
	}

}
